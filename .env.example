# =============================================================================
# Resume PRO Frontend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
# =============================================================================

# ================= API CONFIGURATION =================

# Backend API URL (explicit URL takes priority)
# Use this if your backend is at a fixed URL
VITE_API_URL=http://localhost:5000/api

# Alternative: API port only (will use current hostname)
# Uses port 5000 by default if not set
# VITE_API_PORT=5000

# VITE_API_BASE (legacy, use VITE_API_URL instead)

# ================= SUPABASE (Optional) =================
# Client-side Supabase for auth
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anonymous key (public, safe to expose)
VITE_SUPABASE_ANON_KEY=your-anon-key

# ================= OAUTH (Optional) =================
# Google Sign-In (get from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ================= Razorpay (Optional) =================
# Razorpay Key ID for payment flow (must match backend)
VITE_RAZORPAY_KEY_ID=your-key-id

# =============================================================================
# FEATURE STATUS
# =============================================================================
# Features will be DISABLED if their required variables are not set:
#
# | Feature       | Required Keys                           |
# |--------------|----------------------------------------|
# | Backend API  | VITE_API_URL or VITE_API_PORT          |
# | Supabase     | VITE_SUPABASE_URL, VITE_SUPABASE_KEY  |
# | Google Auth  | VITE_GOOGLE_CLIENT_ID                 |
# | Payments    | VITE_RAZORPAY_KEY_ID                   |
#
# =============================================================================